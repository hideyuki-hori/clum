{
  "comments": { "lineComment": { "comment": "//" } },
  "brackets": [["{", "}"], ["(", ")"]],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [["{", "}"], ["(", ")"], ["'", "'"]],
  "wordPattern": "[A-Za-z][A-Za-z0-9-]*",
  "folding": { "offSide": true }
}
