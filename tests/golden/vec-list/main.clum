# Item name: String

items: Vec<Item> =
  - name: 'First'
  - name: 'Second'
  - name: 'Third'

nums: Vec<i32> =
  - 1
  - 2
  - 3

item-list = items
  |> map item ->
    h .li
      {item.name}

num-list = nums
  |> map n ->
    h .li
      番号 {n}

:pub
index: Html = h .html
  h .body
    h .ul
      {item-list}
    h .ol
      {num-list}

Recipe
  documents:
    - path: './dist/index.html'
      element: index
  |> build
  |> !
